{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ambient.systems/catalog/data-option-v1.json",
  "title": "CatalogDataOption",
  "type": "object",
  "required": ["id", "name", "industry", "metricIds", "fields"],
  "properties": {
    "id": { "type": "integer", "minimum": 1 },
    "name": { "type": "string", "minLength": 1 },
    "industry": { "type": "string" },
    "description": { "type": "string" },
    "format": { "type": "string" },
    "template": { "type": "string" },
    "collectionFrequency": {
      "type": "string",
      "enum": ["daily", "weekly", "monthly", "quarterly", "annual", "yearly"]
    },
    "grain": {
      "type": "string",
      "enum": ["transaction", "day", "week", "month", "quarter"]
    },
    "fieldCoverage": {
      "type": "string",
      "enum": ["upload", "enumerated"]
    },
    "metricIds": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "integer" }
    },
    "fields": {
      "type": "array",
      "items": {
        "oneOf": [
          { "type": "string", "minLength": 1 },
          {
            "type": "object",
            "required": ["name", "type"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "type": {
                "type": "string",
                "enum": [
                  "string",
                  "id",
                  "enum",
                  "integer",
                  "decimal",
                  "date",
                  "timestamp",
                  "boolean",
                  "currency"
                ]
              },
              "nullable": { "type": "boolean" },
              "format": { "type": "string" },
              "unit": { "type": "string" },
              "description": { "type": "string" }
            },
            "additionalProperties": false
          }
        ]
      }
    }
  },
  "additionalProperties": true
}
