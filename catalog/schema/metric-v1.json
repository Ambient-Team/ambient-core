{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ambient.systems/catalog/metric-v1.json",
  "title": "CatalogMetric",
  "type": "object",
  "required": ["id", "name", "industry", "type", "unit", "methodology"],
  "properties": {
    "id": { "type": "integer", "minimum": 1 },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "industry": { "type": "string" },
    "type": { "enum": ["Financial", "Operational"] },
    "unit": { "type": "string" },
    "methodology": { "type": "string" },
    "datasource": { "type": "array", "items": { "type": "string" } },
    "metricIds": { "type": "array", "items": { "type": "integer" } },
    "benchmarkKey": { "type": "string" }
  },
  "additionalProperties": true
}
