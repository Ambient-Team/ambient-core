{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ambient.systems/catalog/manifest-v1.json",
  "title": "CatalogManifest",
  "type": "object",
  "required": ["version", "industries", "metrics", "dataOptions"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "industries": {
      "type": "array",
      "items": { "$ref": "#/$defs/industryEntry" }
    },
    "metrics": {
      "type": "array",
      "items": { "$ref": "#/$defs/manifestMetric" }
    },
    "dataOptions": {
      "type": "array",
      "items": { "$ref": "#/$defs/manifestDataOption" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "industryEntry": {
      "type": "object",
      "required": ["value", "label", "pack", "industryCodes"],
      "properties": {
        "value": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "pack": { "type": "string", "minLength": 1 },
        "industryCodes": { "$ref": "#/$defs/manifestIndustryCodes" }
      },
      "additionalProperties": false
    },
    "taxonomyRef": {
      "type": "object",
      "required": ["revision", "primary"],
      "properties": {
        "revision": { "type": "string", "minLength": 1 },
        "primary": { "type": "string", "minLength": 1 },
        "secondary": {
          "type": "array",
          "maxItems": 2,
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    },
    "manifestIndustryCodes": {
      "type": "object",
      "required": ["isic", "naics", "nace", "gics", "confidence", "lastReviewed", "source"],
      "properties": {
        "isic": { "$ref": "#/$defs/taxonomyRef" },
        "naics": { "$ref": "#/$defs/taxonomyRef" },
        "nace": { "$ref": "#/$defs/taxonomyRef" },
        "gics": { "$ref": "#/$defs/taxonomyRef" },
        "confidence": {
          "enum": ["high", "medium", "low", "provisional"]
        },
        "lastReviewed": { "type": "string", "minLength": 1 },
        "source": {
          "enum": ["manual", "expert", "imported"]
        }
      },
      "additionalProperties": false
    },
    "requiredSource": {
      "type": "object",
      "required": ["catalogOptionKey", "fields"],
      "properties": {
        "catalogOptionKey": { "type": "string", "minLength": 1 },
        "name": { "type": "string" },
        "fields": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "metricCalc": {
      "type": "object",
      "required": ["expr", "inputs"],
      "properties": {
        "expr": { "type": "string", "minLength": 1 },
        "inputs": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "metricInputSource": {
      "type": "object",
      "required": ["catalogOptionKey", "via"],
      "properties": {
        "catalogOptionKey": { "type": "string", "minLength": 1 },
        "id": { "type": "integer" },
        "name": { "type": "string" },
        "field": { "type": "string" },
        "via": { "enum": ["field", "upload"] }
      },
      "additionalProperties": false
    },
    "metricInput": {
      "type": "object",
      "required": ["name", "kind", "covered", "satisfiedBy"],
      "properties": {
        "name": { "type": "string" },
        "kind": { "enum": ["measured", "derived"] },
        "covered": { "type": "boolean" },
        "satisfiedBy": {
          "type": "array",
          "items": { "$ref": "#/$defs/metricInputSource" }
        }
      },
      "additionalProperties": false
    },
    "manifestMetric": {
      "type": "object",
      "required": [
        "catalogMetricKey",
        "id",
        "name",
        "industry",
        "methodology",
        "type",
        "unit",
        "requiredSources"
      ],
      "properties": {
        "catalogMetricKey": { "type": "string", "minLength": 1 },
        "id": { "type": "integer", "minimum": 1 },
        "name": { "type": "string", "minLength": 1 },
        "industry": { "type": "string" },
        "methodology": { "type": "string" },
        "type": { "enum": ["Financial", "Operational"] },
        "unit": { "type": "string" },
        "requiredSources": {
          "type": "array",
          "items": { "$ref": "#/$defs/requiredSource" }
        },
        "calc": {
          "oneOf": [{ "$ref": "#/$defs/metricCalc" }, { "type": "null" }]
        },
        "directlyReported": { "type": "boolean" },
        "inputs": {
          "type": "array",
          "items": { "$ref": "#/$defs/metricInput" }
        },
        "inputCoverage": {
          "enum": ["complete", "upload", "none", "derived", "unspecified"]
        }
      },
      "additionalProperties": false
    },
    "manifestDataOption": {
      "type": "object",
      "required": [
        "catalogOptionKey",
        "id",
        "name",
        "industry",
        "metricIds",
        "fields"
      ],
      "properties": {
        "catalogOptionKey": { "type": "string", "minLength": 1 },
        "id": { "type": "integer", "minimum": 1 },
        "name": { "type": "string", "minLength": 1 },
        "industry": { "type": "string" },
        "metricIds": {
          "type": "array",
          "items": { "type": "integer" }
        },
        "fields": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    }
  }
}
