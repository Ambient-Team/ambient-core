# Maestro / inference — copy to .env.local (gitignored) or export in shell.
# Backend base URLs only; never commit real tokens.

# AMBIENT_MAESTRO_API_KEY=
# MAESTRO_DATABASE_URL=sqlite:///./maestro_runs.db
# MAESTRO_USE_CLASSIFIER=true

# MAESTRO_BACKEND_CLASSIFIER_URL=http://127.0.0.1:11434
# MAESTRO_BACKEND_QWEN32B_URL=http://127.0.0.1:11434
# MAESTRO_BACKEND_DEEPSEEK14B_URL=http://127.0.0.1:11434
# MAESTRO_BACKEND_LLAMA70B_URL=http://127.0.0.1:11434

# MAESTRO_MODELS_FILE=models.ollama-local.yaml

# Optional per-backend API keys:
# MAESTRO_BACKEND_QWEN32B_URL_API_KEY=
